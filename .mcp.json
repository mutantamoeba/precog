{
  "mcpServers": {
    "postgres-dev": {
      "command": "npx",
      "args": ["-y", "@pgedge/pgedge-postgres-mcp-server"],
      "env": {
        "PGHOST": "localhost",
        "PGPORT": "5432",
        "PGDATABASE": "precog_dev",
        "PGUSER": "${DEV_DB_USER}",
        "PGPASSWORD": "${DEV_DB_PASSWORD}"
      }
    }
  }
}
